# Agent System Environment Configuration
# Copy this file to .env and fill in your values

# OpenRouter
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Strong model for coding, repair, architecture, expert tasks
STRONG_MODEL=anthropic/claude-3.5-sonnet

# Cheap model for memory judge, tagging, classification
CHEAP_MODEL=openai/gpt-4o-mini

# Local embedding model (via OpenRouter or local)
EMBEDDING_MODEL=text-embedding-3-small

# Postgres
POSTGRES_USER=agent
POSTGRES_PASSWORD=agentpass
POSTGRES_DB=agentdb
DATABASE_URL=postgresql://agent:agentpass@postgres:5432/agentdb

# MinIO / S3
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minio
S3_SECRET_KEY=miniosecret
S3_BUCKET=agent-memory
MINIO_ROOT_USER=minio
MINIO_ROOT_PASSWORD=miniosecret
